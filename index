<script>

    // 共通タップイベント

    document.querySelectorAll('.hide-box').forEach(box => {

        box.addEventListener('click', () => {

            box.classList.toggle('reveal');

        });

    });



    const songBoxes = document.querySelectorAll('.song-word.hide-box');

    document.getElementById('btn-hide-all').addEventListener('click', () => {

        songBoxes.forEach(box => box.classList.remove('reveal'));

    });

    document.getElementById('btn-show-all').addEventListener('click', () => {

        songBoxes.forEach(box => box.classList.add('reveal'));

    });

</script>




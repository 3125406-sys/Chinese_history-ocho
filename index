<!DOCTYPE html>

<html lang="ja">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>中国史暗記テーブル（シンプル・プリント準拠版）</title>

    <style>

        /* 1. Studioの埋め込み枠内でスクロールがカチコチに固まるのを防ぐ */

        html, body {

            background-color: #f3f4f6;

            margin: 0;

            padding: 10px; /* スマホ向けに余白を少し狭く */

            color: #1f2937;

            font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', Meiryo, sans-serif;

            -webkit-text-size-adjust: 100%; /* スマホでの文字サイズ自動変化を防止 */

        }

        

        .container {

            width: 100%;

            max-width: 950px;

            margin: 0 auto;

            box-sizing: border-box;

        }



        .header {

            text-align: center;

            margin-bottom: 16px;

        }



        .header h1 {

            font-size: 1.3rem; /* スマホで見やすいサイズに少し縮小 */

            color: #111827;

            margin: 0 0 8px 0;

        }



        .header p {

            font-size: 0.8rem;

            color: #6b7280;

            margin: 0;

        }



        /* 2. テーブルが画面外にはみ出しても、ここだけを指で横スクロールできるようにする設定 */

        .table-container {

            width: 100%;

            overflow-x: auto;

            -webkit-overflow-scrolling: touch; /* 縦横スクロールを滑らかにする魔法のプロパティ */

            background: #ffffff;

            border-radius: 12px;

            box-shadow: 0 4px 10px rgba(0,0,0,0.05);

            border: 1px solid #e5e7eb;

            margin-bottom: 20px;

        }



        table {

            width: 100%;

            border-collapse: collapse;

            min-width: 500px; /* 貨幣列削除に伴い、最小幅を少しスリムに調整 */

        }



        th, td {

            border-bottom: 1px solid #f0f0f0;

            padding: 12px 10px;

            text-align: center;

            font-size: 13px; /* スマホで読みやすい標準サイズ */

            line-height: 1.4;

        }



        th {

            background-color: #374151;

            color: #ffffff;

            font-weight: 600;

            font-size: 12px;

            letter-spacing: 0.05em;

        }



        tr:last-child td {

            border-bottom: none;

        }



        tr:nth-child(even) {

            background-color: #f9fafb;

        }

        

        .important {

            color: #ef4444;

            font-weight: bold;

        }

        

        /* 暗記用隠しボタン（マスク） */

        .hide-box {

            background-color: #d1d5db;

            color: #d1d5db;

            cursor: pointer;

            padding: 4px 8px;

            border-radius: 6px;

            user-select: none;

            -webkit-user-select: none; /* iOSでの長押し選択を防止 */

            transition: all 0.2s ease;

            display: inline-block;

            font-weight: bold;

            box-shadow: inset 0 1px 2px rgba(0,0,0,0.1);

        }



        .hide-box.reveal {

            background-color: #fee2e2;

            color: #1f2937;

            box-shadow: none;

        }



        .hide-box.reveal.important {

            color: #ef4444;

        }



        /* 動画エリア */

        .video-card {

            background: #ffffff;

            border: 1px solid #e5e7eb;

            border-radius: 12px;

            padding: 12px;

            box-shadow: 0 4px 10px rgba(0,0,0,0.03);

            text-align: center;

            margin-bottom: 20px;

        }



        .video-card h2 {

            font-size: 1rem;

            color: #1f2937;

            margin-top: 0;

            margin-bottom: 10px;

            line-height: 1.4;

        }



        .video-wrapper {

            position: relative;

            padding-bottom: 56.25%;

            height: 0;

            overflow: hidden;

            border-radius: 8px;

            background: #000;

        }



        .video-wrapper iframe {

            position: absolute;

            top: 0;

            left: 0;

            width: 100%;

            height: 100%;

            border: none;

        }



        /* 覚え歌セクション */

        .song-card {

            background: #eff6ff;

            border: 1px solid #bfdbfe;

            border-radius: 12px;

            padding: 12px;

            box-shadow: 0 4px 10px rgba(0,0,0,0.03);

            margin-bottom: 20px;

        }



        .song-card h2 {

            font-size: 1rem;

            color: #1e3a8a;

            margin-top: 0;

            margin-bottom: 12px;

            text-align: center;

        }



        .song-controls {

            display: flex;

            justify-content: center;

            gap: 10px;

            margin-bottom: 12px;

        }



        .btn {

            padding: 6px 12px;

            font-size: 0.75rem;

            font-weight: bold;

            border-radius: 6px;

            cursor: pointer;

            transition: all 0.2s ease;

            border: 1px solid #cbd5e0;

            user-select: none;

            -webkit-user-select: none;

        }



        .btn-hide {

            background-color: #f1f5f9;

            color: #475569;

        }



        .btn-hide:hover {

            background-color: #e2e8f0;

        }



        .btn-show {

            background-color: #3b82f6;

            color: white;

            border: none;

        }



        .btn-show:hover {

            background-color: #2563eb;

        }



        .song-container {

            display: flex;

            flex-direction: column;

            gap: 12px;

            background: #ffffff;

            padding: 12px 6px;

            border-radius: 8px;

            border: 1px dashed #93c5fd;

        }



        .song-section {

            display: flex;

            flex-direction: column;

            gap: 6px;

            padding-bottom: 10px;

            border-bottom: 1px dashed #e2e8f0;

        }



        .song-section:last-child {

            padding-bottom: 0;

            border-bottom: none;

        }



        .original-lyric {

            font-size: 0.75rem;

            background-color: #f0fdf4;

            border: 1px solid #bbf7d0;

            color: #16a34a;

            padding: 4px 8px;

            border-radius: 4px;

            align-self: center;

            font-weight: bold;

            text-align: center;

            line-height: 1.3;

        }



        .song-row {

            display: flex;

            flex-wrap: wrap;

            justify-content: center;

            gap: 4px;

        }



        .song-word {

            display: inline-flex;

            flex-direction: column;

            align-items: center;

            justify-content: center;

            background: #f8fafc;

            border: 1px solid #e2e8f0;

            padding: 6px 8px;

            border-radius: 6px;

            min-width: 52px;

        }



        .song-word.hide-box {

            background-color: #d1d5db;

            border-color: #cbd5e0;

        }



        .song-word.hide-box:not(.reveal) .kana,

        .song-word.hide-box:not(.reveal) .kanji {

            color: #d1d5db !important;

        }



        .song-word.hide-box.reveal {

            background-color: #fee2e2;

            border-color: #fca5a5;

        }



        .song-word .kana {

            font-size: 0.85rem;

            color: #1e3a8a;

            font-weight: bold;

        }



        .song-word .kanji {

            font-size: 0.75rem;

            color: #64748b;

            margin-top: 1px;

        }



        .song-word.hide-box.reveal .kana { color: #1e3a8a; }

        .song-word.hide-box.reveal .kanji { color: #64748b; }



        .song-note {

            font-size: 0.75rem;

            color: #64748b;

            margin-top: 8px;

            margin-bottom: 0;

            text-align: center;

        }

    </style>

</head>

<body>



